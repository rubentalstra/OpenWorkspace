#!/usr/bin/env bash
# Blocks pushing to main/master and runs the cheap formatting gates before a
# push leaves the machine. Heavier gates (clippy, nextest, deny, audit, build)
# run in CI to keep pushes fast. Activated by: git config core.hooksPath .githooks
set -euo pipefail

remote="${1:-}"
protected_re='^refs/heads/(main|master)$'

while read -r _local_ref _local_sha remote_ref _remote_sha; do
    [[ -z "${remote_ref:-}" ]] && continue
    if [[ "$remote_ref" =~ $protected_re ]]; then
        printf 'push rejected: %s is protected. Open a PR from a feature branch instead.\n' "$remote_ref" >&2
        exit 1
    fi
done

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if command -v cargo >/dev/null 2>&1; then
    if ! cargo fmt --all --check >/dev/null 2>&1; then
        printf 'push rejected: code is not rustfmt-clean. Run: cargo fmt --all\n' >&2
        exit 1
    fi
fi
if command -v leptosfmt >/dev/null 2>&1; then
    if ! leptosfmt --check apps crates >/dev/null 2>&1; then
        printf 'push rejected: view! macros are not leptosfmt-clean. Run: leptosfmt apps crates\n' >&2
        exit 1
    fi
fi

exit 0
