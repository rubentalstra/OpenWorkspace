{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-git.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/fmt-rs.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-rules.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo fmt *)",
      "Bash(cargo clippy *)",
      "Bash(cargo nextest *)",
      "Bash(cargo test *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo deny *)",
      "Bash(cargo audit *)",
      "Bash(cargo sqlx *)",
      "Bash(cargo leptos *)",
      "Bash(cargo tree *)",
      "Bash(cargo metadata *)",
      "Bash(cargo doc *)",
      "Bash(leptosfmt *)",
      "Bash(rustfmt *)",
      "Bash(sqlx *)",
      "Bash(podman compose *)",
      "Bash(podman ps *)",
      "Bash(podman logs *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git fetch *)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git commit *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ]
  }
}
