# Web tier: Leptos SSR server. Rootless multi-stage build with cargo-chef caching.
# Build from the repo root:
#   podman build -f deploy/containers/Containerfile.web -t openworkspace-web .
ARG RUST_VERSION=1.96.0

FROM docker.io/library/rust:${RUST_VERSION}-bookworm AS chef
WORKDIR /app
RUN rustup target add wasm32-unknown-unknown \
 && cargo install --locked cargo-chef cargo-leptos

FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
COPY --from=planner /app/recipe.json recipe.json
# Cache the native dependency build. (wasm deps are rebuilt by cargo-leptos below;
# a skeleton — cook the wasm target too if the wasm build cache becomes a bottleneck.)
RUN cargo chef cook --release --recipe-path recipe.json
COPY . .
RUN cargo leptos build --release

FROM docker.io/library/debian:bookworm-slim AS runtime
WORKDIR /app
RUN groupadd --gid 10001 app && useradd --uid 10001 --gid app --no-create-home app
COPY --from=builder /app/target/release/server /app/server
COPY --from=builder /app/target/site /app/site
ENV LEPTOS_SITE_ROOT=/app/site \
    LEPTOS_SITE_ADDR=0.0.0.0:3000
EXPOSE 3000
USER app
CMD ["/app/server"]
