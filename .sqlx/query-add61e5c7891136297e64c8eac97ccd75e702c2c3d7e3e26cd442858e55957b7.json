{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            u.id,\n            u.email::text AS \"email!\",\n            u.status AS \"status: UserStatusRow\",\n            u.last_login_at,\n            pc.must_change,\n            pc.password_hash\n        FROM users u\n        JOIN password_credentials pc ON pc.user_id = u.id\n        WHERE u.email = $1::citext\n        ",
