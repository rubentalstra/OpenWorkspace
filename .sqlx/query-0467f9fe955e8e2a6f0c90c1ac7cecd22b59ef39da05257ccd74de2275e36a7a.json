  "query": "\n        SELECT f.id, f.name, f.path, b.name AS \"building?\"\n        FROM locations f\n        LEFT JOIN locations b ON b.id = f.parent_id\n        WHERE f.kind = 'floor' AND f.status = 'active'\n        ORDER BY f.path\n        ",
