  "query": "\n        SELECT l.id AS location_id, l.path AS location_path,\n               COALESCE(r.organization_id, l.organization_id) AS org\n        FROM resources r\n        JOIN locations l ON l.id = r.location_id\n        WHERE r.id = $1\n        ",
